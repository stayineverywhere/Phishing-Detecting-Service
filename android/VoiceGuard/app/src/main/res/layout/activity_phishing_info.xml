<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:elevation="2dp">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="@string/common_go"
            app:tint="@color/text_primary"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_info_title"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Section 1: Types -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_section_types"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                style="@style/AppCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/info_type_1"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="검찰, 금융감독원, 경찰 등 공공기관을 사칭해 계좌 동결, 수사 명목으로 금전을 요구하는 수법"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="16dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/info_type_2"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="저금리 대환대출을 미끼로 접근하여 수수료 명목의 선입금을 유도하는 수법"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="16dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/divider" android:layout_marginBottom="16dp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/info_type_3"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/primary"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="가족이나 친구를 사칭해 긴급 상황을 연출하고 즉각적인 송금을 요구하는 수법"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 2: Risk Levels -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_section_risk"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"/>

            <com.google.android.material.card.MaterialCardView
                style="@style/AppCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@color/risk_safe"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/info_risk_1"
                            android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="12dp" android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@color/risk_warning"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/info_risk_2"
                            android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="12dp" android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@color/risk_suspect"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/info_risk_3"
                            android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="12dp" android:textColor="@color/text_primary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <View android:layout_width="12dp" android:layout_height="12dp"
                            android:background="@color/risk_danger"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="@string/info_risk_4"
                            android:textSize="14sp" android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="12dp" android:textColor="@color/text_primary"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>
</LinearLayout>